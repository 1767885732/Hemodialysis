<Window x:Class="Hemo.Client.Login.LoginForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" WindowStyle="None" ResizeMode="NoResize" KeyDown="Window_KeyDown"
             MouseDown="Window_MouseDown" Background="Transparent" AllowsTransparency="True"  ShowInTaskbar="True"  
             Height="270" Width="420" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Topmost="True" >
    <Window.Resources>
        <!--<ImageBrush x:Key="bg1" ImageSource="/Resources/cpoebg.png"/>-->
        <SolidColorBrush x:Key="bg3" Color="#F26621" Opacity="1"/>
        <Style x:Key="okStyle" TargetType="TextBlock">
            <Setter Property="TextDecorations" Value="None" />
            <Setter Property="Foreground" Value="DarkGray"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="officeDataTemplate">
            <TextBlock Foreground="Black" Text="{Binding PERMISSIONNAME}" />
        </DataTemplate>
        <DataTemplate x:Key="officeDataTemplateSelect">
            <TextBlock Text="{Binding PERMISSIONNAME}" Foreground="#FF1616C1" Background="#FFD3CFFC" />
        </DataTemplate>
        <Style x:Key="popupCloseButton" TargetType="TextBlock">
            <Setter Property="TextDecorations" Value="None"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="logEnter" TargetType="{x:Type Grid}">
            <Setter Property="Background" >
                <Setter.Value>
                    <ImageBrush Stretch="Fill" ImageSource="/Resources/loginIco_1.png"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" >
                        <Setter.Value>
                            <ImageBrush Stretch="Fill" ImageSource="/Resources/loginIco_2.png"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="closeNew" TargetType="{x:Type Grid}">
            <Setter Property="Background" >
                <Setter.Value>                   
                    <SolidColorBrush Color="Transparent"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" >
                        <Setter.Value>
                            <SolidColorBrush Color="#D13F26"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="minimizeNew" TargetType="{x:Type Grid}">
            <Setter Property="Background" >
                <Setter.Value>
                    <SolidColorBrush Color="Transparent"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" >
                        <Setter.Value>
                            <SolidColorBrush Color="Black" Opacity="0.2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SeatListStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter></ContentPresenter>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource officeDataTemplateSelect}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTemplate" Value="{StaticResource officeDataTemplate}"></Setter>
        </Style>

    </Window.Resources>
    
    <Grid Background="#FF16499A">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="22"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Grid.Row="0" x:Name="titleLabel"  VerticalAlignment="Center" FontSize="24" Foreground="White" HorizontalAlignment="Left"  Text="DoCare血液净化信息系统" Margin="20,0,0,0" Width="340" TextAlignment="Center" />
        
            <Grid Grid.Column="2" x:Name="miniButton" ToolTip="最小化" MouseLeftButtonDown="minimizeButton_MouseLeftButtonDown" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,0" Width="25" Height="25" Style="{StaticResource minimizeNew}" >
                <TextBlock Text="_"  FontSize="16" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,7" VerticalAlignment="Center" />
            </Grid>
            <Grid Grid.Column="3" x:Name="closeButton" ToolTip="关闭" MouseLeftButtonDown="closeButton_MouseLeftButtonDown" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,0" Width="25" Height="25" Style="{StaticResource closeNew}">
                <TextBlock Text="×" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </Grid>
        <Grid x:Name="loginView" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="250" Grid.Column="1" Visibility="Visible" UseLayoutRounding="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="68"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="9"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Image Source="/Resources/icoHead.png" Opacity="1" Height="69" Width="68"  x:Name="loginimg" VerticalAlignment="Top"  Grid.RowSpan="3"/>
            <ComboBox  x:Name="userName" Foreground="#FF16499A" SelectionChanged="userName_SelectionChanged"  TextBoxBase.TextChanged="userName_TextChanged" HorizontalContentAlignment="Center"  IsEditable="True"  Grid.Column="2" Background="White" VerticalContentAlignment="Center"  Grid.Row="0" Text="DEBUG" UseLayoutRounding="False" OverridesDefaultStyle="False" FontWeight="ExtraBold" />
            <PasswordBox Grid.Row="2" Foreground="#FF16499A" PasswordChanged="password_PasswordChanged" Grid.Column="2" Background="White" x:Name="password" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center" Password="0" />
            <TextBlock x:Name="userNameWatermark" Margin="5,0,0,0" Grid.Column="2" Foreground="DarkGray" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False" Grid.Row="0" Text="用户名"/>
            <TextBlock x:Name="passwordWatermark" Margin="5,0,0,0" Grid.Column="2" Foreground="DarkGray" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False" Grid.Row="2" Text="密码"/>
            <Grid Style="{StaticResource logEnter}" Grid.Row="2" Grid.Column="2" x:Name="loginButton" MouseLeftButtonDown="loginButton_MouseLeftButtonDown"  Width="30"  VerticalAlignment="Stretch" HorizontalAlignment="Right" Margin="0,3,3,3" ForceCursor="False" Cursor="Hand" >
                <!--<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="OK"/>-->            
                
            </Grid>
        </Grid>
        <Grid  Grid.Row="2" Background="Transparent" VerticalAlignment="Stretch"><!--Background="#F26621"-->
            <TextBlock x:Name="copyrightLabel" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="©2014 麦迪斯顿医疗科技股份有限公司"/>
        </Grid>
        <Grid x:Name="loadingView" Visibility="Collapsed" IsHitTestVisible="False" Grid.Row="1">
            <TextBlock  Text="." IsHitTestVisible="False" RenderOptions.CachingHint="Cache" Foreground="White" FontSize="40">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="dot1"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock  Text="." IsHitTestVisible="False" RenderOptions.CachingHint="Cache" Foreground="White" FontSize="40">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="dot2"  />
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock  Text="." IsHitTestVisible="False" RenderOptions.CachingHint="Cache" Foreground="White" FontSize="40">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="dot3"  />
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
        <Grid x:Name="officeView" Grid.Row="1" Width="250" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False" Grid.RowSpan="3" Height="30" >
            <TextBox BorderBrush="DarkGray" VerticalContentAlignment="Center"  TextChanged="offices_TextChanged" x:Name="officeTextBox"  BorderThickness="1" PreviewMouseDoubleClick="officeTextBox_PreviewMouseDoubleClick" />
            <TextBlock IsHitTestVisible="False" Margin="5,0,0,0" x:Name="officeWatermark" Foreground="DarkGray"  VerticalAlignment="Center" Text="输入科室代码 / 选择登陆科室" HorizontalAlignment="Left"  />
            <Grid  x:Name="ok" MouseLeftButtonDown="ok_MouseLeftButtonDown"  Style="{StaticResource logEnter}"  Width="30"  VerticalAlignment="Stretch" HorizontalAlignment="Right" Margin="0,3,3,3" Cursor="Hand">
                <!--<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="OK" Style="{StaticResource okStyle}" />-->
            </Grid>
        </Grid>

        <Grid Grid.Row="0"  IsHitTestVisible="False" x:Name="messageView" Visibility="Collapsed" Background="Transparent"  VerticalAlignment="Bottom" HorizontalAlignment="Left" Grid.ColumnSpan="4" Grid.Column="0">
            <TextBlock Foreground="White" x:Name="message"  FontSize="13" Margin="38,0,0,0" IsHitTestVisible="False"  HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap"/>
        </Grid>
        <Popup x:Name="popup" PlacementTarget="{Binding ElementName=officeTextBox}" Width="250" Height="200" Placement="Bottom">
            <Border Background="White" BorderBrush="DarkGray" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="25"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="officeItems" SelectedValuePath="PERMISSIONNAME" ItemTemplate="{StaticResource officeDataTemplate}" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonUp="officeItems_PreviewMouseLeftButtonUp" />
                    <Border Grid.Row="1" BorderBrush="DarkGray" BorderThickness="0,1,0,0" Background="#f5f5f5">
                        <TextBlock Text="关闭" x:Name="closePopup" MouseLeftButtonDown="closePopup_MouseLeftButtonDown" Style="{StaticResource popupCloseButton}" HorizontalAlignment="Right" Margin="0,0,10,0" Foreground="#FF16499A" Cursor="Hand" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
