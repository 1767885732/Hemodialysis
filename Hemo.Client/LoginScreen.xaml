<Window x:Class="Hemo.Client.LoginScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"  Loaded="Window_Loaded"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  ResizeMode="NoResize" 
             WindowStyle="None" ShowInTaskbar="True"  WindowStartupLocation="CenterScreen"  Background="Transparent" AllowsTransparency="True"
             mc:Ignorable="d"  MouseDown="Window_MouseDown"
              Width="400"  Height="300">
    <Window.Resources>
        <ImageBrush x:Key="bg1" ImageSource="Resources/bg1.jpg"/>
        <ImageBrush x:Key="bg2" ImageSource="Resources/bg2.jpg"/>
        <Style x:Key="cancelStyle" TargetType="TextBlock">
            <Setter Property="TextDecorations" Value="None" />
            <Setter Property="Foreground" Value="DarkGray"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <SolidColorBrush x:Key="bg3" Color="Black" Opacity="0.3"/>
        <DataTemplate x:Key="officeDataTemplate">
            <TextBlock Text="{Binding PERMISSIONNAME}" />
        </DataTemplate>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Storyboard x:Key="loading">
            <DoubleAnimation BeginTime="00:00:00" From="0" To="1" RepeatBehavior="Forever" AccelerationRatio="0.3" DecelerationRatio="0.7" FillBehavior="Stop" Duration="00:00:05" AutoReverse="True" Storyboard.TargetName="bg2" Storyboard.TargetProperty="Opacity"/>
        </Storyboard>
        <Style x:Key="close" TargetType="{x:Type Border}">
            <Setter Property="Background" >
                <Setter.Value>
                    <ImageBrush Stretch="Fill" ImageSource="Resources/clouse.png"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" >
                        <Setter.Value>
                            <ImageBrush Stretch="Fill" ImageSource="Resources/clouse_hover.png" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="minimize" TargetType="{x:Type Grid}">
            <Setter Property="Background" >
                <Setter.Value>
                    <ImageBrush Stretch="Fill" ImageSource="Resources/minimize.png"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" >
                        <Setter.Value>
                            <ImageBrush Stretch="Fill" ImageSource="Resources/minimize_hover.png"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="73"/>
            <ColumnDefinition Width="15"/>
            <ColumnDefinition Width="165"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="10" Grid.RowSpan="10" IsHitTestVisible="False" BorderBrush="DarkGray" Padding="0" BorderThickness="1" Background="{StaticResource bg1}" CornerRadius="10"/>
        <Border Grid.ColumnSpan="10" Grid.RowSpan="10" IsHitTestVisible="False" x:Name="bg2" BorderThickness="0" CornerRadius="10" Opacity="0"   Background="{StaticResource bg2}"/>
        <TextBlock Grid.Row="1" Grid.Column="1"  VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="20" Text="DoCare血液净化信息系统V2.0" Grid.ColumnSpan="5" Width="284" Margin="11,0,0,0" />
        <TextBlock x:Name="logining" FontSize="13" IsHitTestVisible="False" Text="正在验证帐号" Foreground="Black" Visibility="Collapsed" Grid.Row="2" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="3" HorizontalAlignment="Left" Margin="12,25,0,0" VerticalAlignment="Top">
            <TextBlock.RenderTransform>
                <TranslateTransform x:Name="loggingTranslateTransform"/>
            </TextBlock.RenderTransform>
        </TextBlock>
        <TextBlock  FontSize="12" Text="XX公司  保留所有权利" Foreground="DarkGray" VerticalAlignment="Center"  HorizontalAlignment="Left" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4"/>
        <TextBlock Text="取消" FontSize="12" x:Name="cancle" Style="{StaticResource cancelStyle}" Grid.Row="4" Cursor="Hand"  ToolTip="取消" MouseLeftButtonDown="cancle_MouseLeftButtonDown"  VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Column="5"/>
        <Grid Grid.Row="3" x:Name="logView" Width="270" Height="60" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.Column="0" Grid.ColumnSpan="10" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <ComboBox x:Name="userName" SelectionChanged="userName_SelectionChanged" VerticalContentAlignment="Center" IsEditable="True"  TextBoxBase.TextChanged="userName_TextChanged" Height="25" BorderBrush="DarkGray" BorderThickness="1" VerticalAlignment="Center" Grid.Row="0"/>
            <PasswordBox x:Name="password" KeyDown="password_KeyDown" VerticalContentAlignment="Center" PasswordChanged="password_PasswordChanged" Height="25" BorderBrush="DarkGray" BorderThickness="1" VerticalAlignment="Center" Grid.Row="1"/>
            <TextBlock x:Name="userNameWatermark" Grid.Row="0"  Foreground="DarkGray" HorizontalAlignment="Left" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0" Text="用户名"/>
            <TextBlock x:Name="passwordWatermark" Grid.Row="1"  Foreground="DarkGray" HorizontalAlignment="Left" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0" Text="密码"/>
            <Image Source="Resources/login.png" Opacity="1" ToolTip="登陆" x:Name="loginButton" MouseLeftButtonDown="loginButton_MouseLeftButtonDown" Cursor="Hand" Grid.Column="1" Margin="3,3,0,3" Grid.RowSpan="2"/>
        </Grid>
        <Border CornerRadius="0,0,10,10" Height="30" IsHitTestVisible="False" x:Name="messageView" Visibility="Collapsed" Background="{StaticResource bg3}" Margin="0,0,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Grid.Row="0" Grid.RowSpan="10" Grid.Column="0" Grid.ColumnSpan="10">
            <TextBlock Foreground="White" x:Name="message"  FontSize="13" IsHitTestVisible="False" Margin="10,0,0,0"  HorizontalAlignment="Left" VerticalAlignment="Center" TextWrapping="Wrap"/>
        </Border>
        <Grid Height="40" x:Name="officeView" Visibility="Collapsed" Background="{StaticResource bg3}" Margin="0,0,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Grid.Row="3"  Grid.Column="0" Grid.ColumnSpan="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="offices" Grid.ColumnSpan="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" IsEditable="True" TextBoxBase.TextChanged="offices_TextChanged" KeyDown="officeCode_KeyDown" Height="25" Margin="0,0,2.5,0" Grid.Column="1" VerticalAlignment="Center" BorderBrush="DarkGray" BorderThickness="1" SelectionChanged="offices_SelectionChanged" ItemTemplate="{StaticResource officeDataTemplate}"  />
            <!--<TextBlock IsHitTestVisible="False" Grid.Column="1" Grid.ColumnSpan="2" x:Name="officeWatermark"  Margin="10,0,0,0" Foreground="DarkGray"  VerticalAlignment="Center" Text="选择登陆模块"/>-->
            <TextBlock Text="登 陆" FontSize="12"  Foreground="White" x:Name="ok" Style="{StaticResource cancelStyle}" Grid.Row="4" Cursor="Hand"  ToolTip="登陆" MouseLeftButtonDown="ok_MouseLeftButtonDown" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Column="3"/>
        </Grid>
        <Grid Style="{StaticResource minimize}" Height="20"  ToolTip="最小化" VerticalAlignment="Top" x:Name="minimizeButton"  MouseLeftButtonDown="minimizeButton_MouseLeftButtonDown" Grid.Column="5"/>
        <Border CornerRadius="0,10,0,0" ToolTip="关闭" Style="{StaticResource close}" Height="20" VerticalAlignment="Top" x:Name="closeButton"  MouseLeftButtonDown="closeButton_MouseLeftButtonDown"  Grid.Column="6" />
    </Grid>
</Window>
