        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="FangSong" FontSize="17"  Height="23" HorizontalAlignment="Right" IsReadOnly="False" Margin="0,280,402,997" Name="textBox2" Width="234" />
