        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="FangSong" FontSize="17"  Height="23" HorizontalAlignment="Left" IsReadOnly="False" Margin="180,1174,0,103" Name="textBox10" Width="37" Text="无" />
