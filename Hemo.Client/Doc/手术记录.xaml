        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="FangSong" FontSize="17"  Height="23" HorizontalAlignment="Right" IsReadOnly="False" Margin="0,322,314,0" Name="textBox3" VerticalAlignment="Top" Width="128" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="FangSong" FontSize="17"  Height="23" HorizontalAlignment="Left" IsReadOnly="False" Margin="180,322,0,955" Name="textBox4" Width="129" />
        <Label Content="护士：" FontFamily="FangSong" FontSize="17"  Height="29" HorizontalAlignment="Left" Margin="508,318,0,0" Name="label12" VerticalAlignment="Top" Width="53" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="FangSong" FontSize="17"  Height="23" HorizontalAlignment="Right" IsReadOnly="False" Margin="0,322,53,0" Name="textBox5" VerticalAlignment="Top" Width="196" />
        <Label Content="麻 醉 者：" FontFamily="FangSong" FontSize="17"  Height="29" HorizontalAlignment="Left" Margin="84,362,0,0" Name="label13" VerticalAlignment="Top" Width="90" />
        <Label Content="麻醉方式：" FontFamily="FangSong" FontSize="17"  Height="29" HorizontalAlignment="Left" Margin="315,362,0,0" Name="label14" VerticalAlignment="Top" Width="88" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="FangSong" FontSize="17"  Height="23" HorizontalAlignment="Right" IsReadOnly="False" Margin="0,366,314,0" Name="textBox6" VerticalAlignment="Top" Width="93" />
