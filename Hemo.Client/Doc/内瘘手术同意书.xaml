        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Right" Margin="0,1059,62,0" Name="label11" VerticalAlignment="Top" Width="85" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="宋体" FontSize="17"  Height="23" IsReadOnly="False" Margin="141,233,0,0" Name="txtPATIENTID" VerticalAlignment="Top" HorizontalAlignment="Left" Width="105" />
        <Label Content="ID号：" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="84,229,0,0" Name="label27" VerticalAlignment="Top" Width="53" />
