<?xml version="1.0"?>
<configuration>
  <appSettings>
    <add key="HemoRecord-EMRTYPE" value="血液透析记录" />
    <add key="GetPatientInfoSql" value="SELECT T.PATIENT_ID PATIENTID,T.NAME PATIENTNAME,T.SEX PATIENTSEX,T.BIRTHDAY BIRTHDAY,T.AGE AGE FROM MED_PATIENTS T WHERE T.PATIENT_ID='{0}'" />
  </appSettings>
  <connectionStrings>
    <add name="docare" connectionString="Data Source=hemo95;Persist Security Info=True;Password=medhemo;User ID=medhemo"
               providerName="System.Data.oracleclient" />  </connectionStrings>
  <system.web>
    <compilation debug="true" targetFramework="4.0">
    </compilation>
    <!--
      通过 <authentication> 节可以配置
      安全身份验证模式，ASP.NET 
      使用该模式来识别来访用户身份。 
    -->
    <authentication mode="Windows"/>
    <!--
       如果在执行请求的过程中出现未处理的错误
       则通过 <customErrors> 节
       可以配置相应的处理步骤。具体而言，
       开发人员通过该节可配置要显示的 html 错误页，
       以代替错误堆栈跟踪。

       <customErrors mode="RemoteOnly" defaultRedirect="GenericErrorPage.htm">
         <error statusCode="403" redirect="NoAccess.htm" />
         <error statusCode="404" redirect="FileNotFound.htm" />
       </customErrors>
    -->
    <pages controlRenderingCompatibilityVersion="4.0" clientIDMode="AutoID"/>
  </system.web>
</configuration>
