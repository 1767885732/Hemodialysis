<?xml version="1.0"?>
<configuration>
  <system.serviceModel>
    <client>
      <endpoint address="net.tcp://localhost:8888/Hemo.Service/ExceptionLogService/" binding="netTcpBinding" bindingConfiguration="netTcp" contract="Hemo.IService.IExceptionLogService" name="Hemo.Service.ExceptionLogService"></endpoint>
    </client>
    <bindings>
      <netTcpBinding>
        <binding name="netTcp" maxBufferPoolSize="2147483647" maxReceivedMessageSize="2147483647"></binding>
      </netTcpBinding>
    </bindings>
  </system.serviceModel>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0"/></startup></configuration>
