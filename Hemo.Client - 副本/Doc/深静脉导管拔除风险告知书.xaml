<UserControl x:Class="Hemo.Client.Doc.深静脉导管拔除风险告知书"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1100" d:DesignWidth="816">
    <Grid>
        <Label Content="血液净化科" FontFamily="宋体" FontSize="26"  Height="50" HorizontalAlignment="Left" HorizontalContentAlignment="Center" Margin="141,76,0,0" Name="lblHospital" VerticalAlignment="Top" VerticalContentAlignment="Center" Width="522" FontStyle="Normal" />
        <Label Content="血液透析用深静脉导管拔除风险告知书" FontSize="22" Height="44" HorizontalAlignment="Left" HorizontalContentAlignment="Center" Margin="202,132,0,0" Name="label2" VerticalAlignment="Top" VerticalContentAlignment="Center" Width="405" FontFamily="宋体"  />
        <Label Content="姓名：" Height="27" HorizontalAlignment="Left"  Name="label3" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="51" Margin="84,196,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtName" IsReadOnly="False" Margin="0,200,583,0" HorizontalAlignment="Right" Width="92" FontSize="17" FontFamily="宋体"  VerticalAlignment="Top" />
        <Label Content="性别：" Height="27" HorizontalAlignment="Left"  Name="label33" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="51" Margin="237,196,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtSex" IsReadOnly="False" Margin="294,200,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="98" FontSize="17" FontFamily="宋体"  />
        <Label  Content="年龄：" Height="27" HorizontalAlignment="Left"  Name="label34" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="53" Margin="398,196,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtAge" IsReadOnly="False" Margin="457,200,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="99" FontSize="17" FontFamily="宋体"  />
        <Label Content="门诊/住院号：" Height="28" Name="label6" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Margin="562,196,0,0" HorizontalAlignment="Left" Width="118" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtAdmissionNumber" IsReadOnly="False" Margin="0,200,53,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="77" FontSize="17" FontFamily="宋体"  />
        <Label Content="诊断：" Height="29" HorizontalAlignment="Left"  Name="label31" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="50" Margin="84,234,0,0" />
        <Label Content="血管通路情况：" Height="29" HorizontalAlignment="Left"  Name="label32" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="123" Margin="367,234,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtVascularAccess" IsReadOnly="False" Margin="496,238,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="267"  FontSize="17" FontFamily="宋体" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="22" HorizontalAlignment="Left" LineHeight="35" Margin="84,269,0,0" Name="textBlock3" Text="深静脉导管拔除可能有以下风险：" TextWrapping="Wrap" VerticalAlignment="Top" Width="679" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="273" HorizontalAlignment="Left" LineHeight="35" Margin="84,297,0,0" Name="textBlock5" Text="1.麻醉意外；
2.心脑血管意外；
3.切口感染，严重者出现败血症；
4.大出血，严重者出血性休克导致死亡；
5.可能出现血栓栓子脱落，引起一系列并发症，如肺栓塞、脑梗塞等全身其他脏器的栓塞梗死，甚至危及生命；
6.导管内移进入血管，需血管介入技术拔除；
7.由于医学的复杂性，可能发生其他不可预见的并发症。
" TextWrapping="Wrap" VerticalAlignment="Top" Width="679" />
        <Label Content="患者/家属签名：" FontFamily="宋体" FontSize="15"  Height="25" HorizontalAlignment="Left" Margin="490,945,0,0" Name="label4" VerticalAlignment="Top" Width="132" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" Margin="628,945,0,0" Name="label7" VerticalAlignment="Top" Width="135" />
        <Label Content="家属与患者关系：" FontFamily="宋体" FontSize="15"  Height="25" HorizontalAlignment="Left" Margin="490,976,0,0" Name="label8" VerticalAlignment="Top" Width="132" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" Margin="628,976,0,0" Name="label9" VerticalAlignment="Top" Width="135" />
        <Label Content="告知医师签字：" FontFamily="宋体" FontSize="15"  Height="25" HorizontalAlignment="Left" Margin="490,1007,0,0" Name="label10" VerticalAlignment="Top" Width="132" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" Margin="628,1007,0,0" Name="label11" VerticalAlignment="Top" Width="135" />
        <Label Content="      年    月    日" FontFamily="宋体" FontSize="17"  Height="34" HorizontalAlignment="Left" Margin="578,1038,0,0" Name="lblDate" VerticalAlignment="Top" Width="185" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="宋体" FontSize="17"  Height="23" HorizontalAlignment="Right" IsReadOnly="False" Margin="0,238,455,839" Name="txtDiagnose" Width="220" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Black" Height="60" HorizontalAlignment="Left" LineHeight="35" Margin="84,579,0,0" Name="textBlock4" Text="    高度怀疑深静脉置管部位血管血栓形成，特别是在影像学检查证实血栓存在的情况下，可考虑在介入技术下拔除，以减少栓子脱落带来的风险。" TextWrapping="Wrap" VerticalAlignment="Top" Width="679" FontStyle="Normal" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Black" Height="60" HorizontalAlignment="Left" LineHeight="35" Margin="84,655,0,0" Name="textBlock1" Text="    医生已明确告知深静脉导管拔除可能带来的以上医疗风险，病人和/或家属已充分理解，接受深静脉导管直接拔除术，理解其风险并配合治疗，签字为证。" TextWrapping="Wrap" VerticalAlignment="Top" Width="679" />
    </Grid>
</UserControl>
