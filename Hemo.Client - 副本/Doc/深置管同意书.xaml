<UserControl x:Class="Hemo.Client.Doc.深置管同意书"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1100" d:DesignWidth="816">
    <Grid>
        <Label Content="" FontFamily="宋体" FontSize="26"  Height="50" HorizontalAlignment="Left" HorizontalContentAlignment="Center" Margin="141,76,0,0" Name="lblHospital" VerticalAlignment="Top" VerticalContentAlignment="Center" Width="522" FontStyle="Normal" />
        <Label Content="深静脉穿刺插管术前志愿书" FontSize="22" Height="44" HorizontalAlignment="Left" HorizontalContentAlignment="Center" Margin="202,132,0,0" Name="label2" VerticalAlignment="Top" VerticalContentAlignment="Center" Width="405" FontFamily="宋体"  />
        <Label Content="姓名：" Height="27" HorizontalAlignment="Left"  Name="label3" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="51" Margin="84,196,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtName" IsReadOnly="False" Margin="141,200,0,877" HorizontalAlignment="Left" Width="88" FontSize="17" FontFamily="宋体"  />
        <Label Content="性别：" Height="27" HorizontalAlignment="Left"  Name="label33" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="51" Margin="235,196,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtSex" IsReadOnly="False" Margin="0,200,467,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="60" FontSize="17" FontFamily="宋体"  />
        <Label  Content="年龄：" Height="27" HorizontalAlignment="Left"  Name="label34" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="53" Margin="355,196,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtAge" IsReadOnly="False" Margin="414,200,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="43" FontSize="17" FontFamily="宋体"  />

        <Label  Content="科室：" Height="27" HorizontalAlignment="Left"  Name="label41" VerticalAlignment="Top" FontSize="17" FontFamily="宋体"  Width="53" Margin="455,196,0,0" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtDeptCode" IsReadOnly="False" Margin="514,200,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="102" FontSize="17" FontFamily="宋体"  />
        <Label  Content="拟施操作：" HorizontalAlignment="Left"  Name="label43" FontSize="17" FontFamily="宋体"  Width="112" Margin="84,260,0,0" VerticalAlignment="Top" />
        <TextBox Height="23"  BorderThickness="0,0,0,0" BorderBrush="Black" Name="txtAddress" IsReadOnly="False" Margin="0,267,479,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="135" FontSize="17" FontFamily="宋体"  />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="88,298,0,0" Name="textBlock5" Text="深静脉穿刺插管术适应证及禁忌证：" TextWrapping="Wrap" VerticalAlignment="Top" Width="304" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="135" HorizontalAlignment="Left" LineHeight="35" Margin="92,329,0,0" Name="textBlock1" Text="1、需长期静脉输液；
2、必要时中心静脉压测定；
3、维持性血液透析；
4、无明显禁忌证。   
" TextWrapping="Wrap" VerticalAlignment="Top" Width="670" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="88,470,0,0" Name="textBlock2" Text="深静脉穿刺插管术中术后可能出现的并发症和医疗意外：" TextWrapping="Wrap" VerticalAlignment="Top" Width="443" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="88,839,0,0" Name="textBlock4" Text="患方意见" TextWrapping="Wrap" VerticalAlignment="Top" Width="270" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="100" HorizontalAlignment="Left" LineHeight="35" Margin="88,0,0,130" Name="textBlock6" Text="  有关深静脉穿刺插管术中和术后可能发生的并发症及医疗意外，医生已向我们详细阐明，家属或患者及单位完全理解，由于病情需要，经慎重考虑，同意行术颈内静脉穿刺插管术，签字生效。" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="670" />
        <Label Content="患者签名" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="84,998,0,0" Name="label19" VerticalAlignment="Top" Width="78" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" Margin="168,1000,0,0" Name="label20" VerticalAlignment="Top" Width="135" />
        <Label ClipToBounds="False" Content="主治医生" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="309,1027,0,0" Name="label21" VerticalAlignment="Top" Width="83" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Right" Margin="0,1029,283,0" Name="label22" VerticalAlignment="Top" Width="135" />
        <Label Content="家属签名" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="312,994,0,0" Name="label4" VerticalAlignment="Top" Width="78" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" Margin="396,996,0,0" Name="label7" VerticalAlignment="Top" Width="135" />
        <Label FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="537,994,0,0" Name="label8" VerticalAlignment="Top" Width="95" Content="与患者关系" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Right" Margin="0,996,43,0" Name="label9" VerticalAlignment="Top" Width="135" />
        <Label ClipToBounds="False" Content="科主任" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="539,1027,0,0" Name="label10" VerticalAlignment="Top" Width="93" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Right" Margin="0,1029,43,0" Name="label11" VerticalAlignment="Top" Width="135" />
        <Label Content="谈话医生" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="88,0,0,46" Name="label23" VerticalAlignment="Bottom" Width="83" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Right" Margin="0,1029,513,0" Name="label24" VerticalAlignment="Top" Width="135" />
        <Label ClipToBounds="False" Content="日期" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="539,1063,0,0" Name="label25" VerticalAlignment="Top" Width="45" />
        <Label Content="" FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Right" Margin="0,1063,43,0" Name="label26" VerticalAlignment="Top" Width="135" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="宋体" FontSize="17"  Height="23" HorizontalAlignment="Left" IsReadOnly="False" Margin="667,200,0,0" Name="txtPATIENTID" VerticalAlignment="Top" Width="145" />
        <Label Content="ID号：" FontFamily="宋体" FontSize="17"  Height="27" HorizontalAlignment="Left" Margin="610,0,0,877" Name="label27" VerticalAlignment="Bottom" Width="53" />
        <Label Content="诊断：" FontFamily="宋体" FontSize="17"  HorizontalAlignment="Left" Margin="84,228,0,0" Name="label28" VerticalAlignment="Top" Width="112" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="宋体" FontSize="17"  Height="23" HorizontalAlignment="Right" IsReadOnly="False" Margin="0,232,62,0" Name="textBox1" VerticalAlignment="Top" Width="552" />
        <Label Content="拟行麻醉：" FontFamily="宋体" FontSize="17"  HorizontalAlignment="Left" Margin="360,263,0,0" Name="label29" VerticalAlignment="Top" Width="97" />
        <TextBox BorderBrush="Black" BorderThickness="0,0,0,0" FontFamily="宋体" FontSize="17"  Height="23" HorizontalAlignment="Right" IsReadOnly="False" Margin="0,267,217,0" Name="textBox2" VerticalAlignment="Top" Width="135" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="166" HorizontalAlignment="Left" LineHeight="35" Margin="92,499,0,0" Name="textBlock8" Text="1、术后静脉血栓形成；
2、穿刺部位皮下积血；
3、术后穿刺部位感染； 
4、因解剖变异导致穿刺不成功；
5、其他意外情况" TextWrapping="Wrap" VerticalAlignment="Top" Width="670" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="92,670,0,0" Name="textBlock3" Text="医院声明：" TextWrapping="Wrap" VerticalAlignment="Top" Width="270" />
        <TextBlock FontFamily="宋体" FontSize="17"  Height="127" HorizontalAlignment="Left" LineHeight="35" Margin="92,701,0,0" Name="textBlock9" Text="  医生将严格按照医疗工作制度及操作常规进行深静脉穿刺插管术,尽量避免以上情况的发生。但由于某些不可预知的原因以上情况有时仍有可能发生。当然医院会尽力救治，但经抢救后即使效果不佳或无效，院方仍将按规定收取医疗费用。患者或家属及单位应做好思想准备。若同意行深静脉穿刺插管术，签字为证。如不同意，医院决不勉强。" TextWrapping="Wrap" VerticalAlignment="Top" Width="670" />
    </Grid>
</UserControl>
