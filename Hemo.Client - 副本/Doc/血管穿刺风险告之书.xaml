<UserControl x:Class="Hemo.Client.Doc.血管穿刺风险告之书"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
           d:DesignHeight="1200" d:DesignWidth="760">
    <Grid>
        <Label Content="" FontFamily="宋体" FontSize="26" FontStyle="Normal"  Height="50" HorizontalAlignment="Left" HorizontalContentAlignment="Center" Margin="199,12,0,0" Name="lblHospital" VerticalAlignment="Top" VerticalContentAlignment="Center" Width="395" />
        <Label Content="血液净化血管穿刺术风险告知书" FontFamily="宋体" FontSize="22"  Height="44" HorizontalAlignment="Left" HorizontalContentAlignment="Center" Margin="10,60,0,0" Name="label2" VerticalAlignment="Top" VerticalContentAlignment="Center" Width="745" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="140" HorizontalAlignment="Left" LineHeight="30" Margin="85,111,0,0" Name="textBlock1" Text="    血液透析是清除血液中氮源性及其他源性代谢废物，纠正与肾衰竭相关的水、电解质、酸碱平衡紊乱的一种治疗慢性肾衰竭方法之一。但是在血液净化治疗前首先要进行血管穿刺，包括：动静脉内瘘穿刺，动、静脉直接穿刺术等，由于患者可能存在凝血功能障碍及血液净化过程中需要抗凝，因此在穿刺术中、术后可能出现一些并发症，现告知如下：" TextWrapping="Wrap" VerticalAlignment="Top" Width="605" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="85,260,0,0" Name="textBlock2" Text="一、 穿刺风险：" TextWrapping="Wrap" VerticalAlignment="Top" Width="135" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="95" HorizontalAlignment="Left" LineHeight="30" Margin="85,284,0,0" Name="textBlock3" Text="（1） 因解剖变异导致穿刺不成功，局部皮肤出现肿胀，严重者可能出现间隙挤压综合征，将行局部皮肤切开减压术；                                 （2） 动脉穿刺出现假性动脉瘤，导致动脉瘤破裂出血，可危及生命；" TextWrapping="Wrap" VerticalAlignment="Top" Width="605" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="85,375,0,0" Text="二、 可能发生的并发症：" TextWrapping="Wrap" VerticalAlignment="Top" Width="201" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="85" HorizontalAlignment="Left" LineHeight="30" Margin="85,400,0,0" Text="（1） 穿刺部位出血、皮下积血、肿胀；     （2） 术后穿刺部位感染；                                           （3） 局部消毒剂及胶布过敏；             （4） 假性动脉瘤；                                                 （5） 瘘管阻塞；" TextWrapping="Wrap" VerticalAlignment="Top" Width="605" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="85,487,0,0" Text="三、 注意事项：" TextWrapping="Wrap" VerticalAlignment="Top" Width="201" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="505" HorizontalAlignment="Left" LineHeight="30" Margin="85,512,0,0" Text="（1） 已经做好内瘘手术的病人平时应戴护腕，防止动脉瘤样扩张；       （2） 内瘘穿刺针眼应保持清洁干燥，预防感染，避免在内瘘侧肢体测血压、抽血、输液、压迫等，以防瘘管栓塞；                                   （3） 内瘘拔针后压迫力量应适当，不宜过紧或过松，包扎纱布2小时左右即可解开；                                                               （4） 穿刺桡动脉、足背动脉的患者，透析结束用另侧拇指压迫止血20分钟，无出血或渗血才可松开手指，继续包扎六小时后解除包扎，并继续观察穿刺点止血情况。穿刺处肢体当日不可用力活动，足背穿刺者当日避免站立行走，应卧床休息12小时。如果发现包扎处纱布有渗血应先压迫穿刺点，同时报告医护人员给予处理。若出现皮下淤血，应用喜疗妥药膏避开针眼在淤血部位涂抹，以便促进局部淤血吸收；                                                       （5） 行内瘘、桡动脉、足背动脉穿刺的血管，应避开透析当天给予热敷，每天3次，每次30分钟，使血管软化避免产生硬结，热敷时温度切勿太高，以免烫伤皮肤。透析结束返血时为了安全，管道内会有极少量血液残留，属正常现象，请不必惊慌。                                                           （6） 病人和/或家属已接受动静脉内瘘（动脉）穿刺术风险告知书，并要求接受动静脉内瘘（动脉）穿刺术。" TextWrapping="Wrap" VerticalAlignment="Top" Width="605" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="85,1019,0,156" Text="病人/家属意见：" TextWrapping="Wrap" Width="135" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="85,1057,0,0" Text="病人/家属签名：" TextWrapping="Wrap" VerticalAlignment="Top" Width="135" />
        <Image Name="imgPatientSign" HorizontalAlignment="Left" Margin="225,1050,0,0" VerticalAlignment="Top" Width="150" Height="40"/>
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="456,1019,0,0" Text="告知医师/护士签名：" TextWrapping="Wrap" VerticalAlignment="Top" Width="173" />
        <TextBlock FontFamily="宋体" FontSize="17" FontWeight="Normal" Height="25" HorizontalAlignment="Left" LineHeight="35" Margin="500,1057,0,0" Text="年       月      日" TextWrapping="Wrap" VerticalAlignment="Top" Width="207" />
    </Grid>
</UserControl>
